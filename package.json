{
    "name": "personal-website-react",
    "version": "0.2.0",
    "homepage": "https://jolienhoop.com",
    "description": "This is a clean customizable portfolio template for developers.",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/JoHoop/personal-website-react.git"
    },
    "author": "Jo Lienhoop <hey@jolienhoop.com>",
    "license": "MIT",
    "dependencies": {
        "@google/generative-ai": "^0.24.1",
        "@material-ui/core": "^4.11.0",
        "@material-ui/icons": "^4.9.1",
        "@material-ui/lab": "^4.0.0-alpha.56",
        "@testing-library/jest-dom": "^4.2.4",
        "@testing-library/react": "^9.3.2",
        "@testing-library/user-event": "^7.1.2",
        "classnames": "^2.2.6",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^4.22.1",
        "ios-inner-height": "^1.1.1",
        "popmotion": "^8.7.3",
        "react": "^16.13.1",
        "react-dom": "^16.13.1",
        "react-helmet": "^6.1.0",
        "react-router-dom": "^5.2.0",
        "react-scripts": "^5.0.1",
        "react-snapshot": "^1.3.0",
        "react-transition-group": "^4.4.1",
        "react-typical": "^0.1.3",
        "three": "^0.125.0",
        "use-dencrypt-effect": "1.0.1"
    },
    "scripts": {
        "server": "node server.mjs",
        "start": "react-scripts start",
        "build": "react-scripts build && react-snapshot",
        "test": "react-scripts test",
        "eject": "react-scripts eject"
    },
    "reactSnapshot": {
        "exclude": [
            "/resume"
        ],
        "snapshotDelay": 1000
    },
    "eslintConfig": {
        "extends": "react-app",
        "parserOptions": {
            "ecmaVersion": 2022,
            "sourceType": "module"
        }
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "main": "server.mjs",
    "devDependencies": {
        "jest": "^27.5.1"
    },
    "keywords": [],
    "bugs": {
        "url": "https://github.com/JoHoop/personal-website-react/issues"
    }
}
